# Environment variables for Diwanic
# Copy this file to .env and fill in your values

# Scraper
SCRAPER_BASE_URL=https://www.aldiwan.net
SCRAPER_DELAY=1.5

# Embedding
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Qdrant Cloud (free tier)
# 1. Create account at https://cloud.qdrant.io
# 2. Create a free cluster
# 3. Copy the URL and API key below
QDRANT_URL=https://your-cluster-name.cloud.qdrant.io
QDRANT_API_KEY=your-api-key-here

# Qdrant Local (alternative to cloud)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# PostgreSQL (optional for production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/diwanic