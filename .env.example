# ──────────────────────────────────────────────────────────────────────
# Diwanic — Environment Variables (example for local Docker Compose)
# ──────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your actual values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────

# Local Postgres credentials (used by docker-compose.yml)
POSTGRES_USER=diwanic
POSTGRES_PASSWORD=diwanic_secret
POSTGRES_DB=diwanic

# Router (9Router) — required for intent parsing
# Point to host.docker.internal if 9Router runs on your host machine
ROUTER__BASE_URL=http://host.docker.internal:20128/v1
ROUTER__API_KEY=your-api-key-here
ROUTER__MODEL=my-combo

# ROUTER__BASE_URL=http://host.docker.internal:20128/v1
# ROUTER__API_KEY=your-api-key-here
# ROUTER__MODEL=my-combo


# Logfire (optional — uncomment to enable observability)
# LOGFIRE_TOKEN=your-logfire-token-here
